# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (ห้าม commit .env.local)

# ── Supabase ───────────────────────────────────────────────
# หาค่าได้ที่ Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://ryewggkhunpuipgkgbfv.supabase.co
# service_role key (secret — ใช้ฝั่งเซิร์ฟเวอร์เท่านั้น ห้ามหลุดไปเบราว์เซอร์)
SUPABASE_SERVICE_ROLE_KEY=

# ── กุญแจตัว AI (API key) ───────────────────────────────────
# ใส่เฉพาะเจ้าที่จะใช้ก็พอ · เว้นว่างไว้ได้ · "พื้นฐาน" ไม่ต้องใช้กุญแจเลย
# ทุกกุญแจอยู่ฝั่งเซิร์ฟเวอร์เท่านั้น ไม่หลุดเบราว์เซอร์

# Gemini (ฟรี) — ขอที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Claude (pro) — ขอที่ https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# GPT / OpenAI (pro) — ขอที่ https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek (ถูกมาก) — ขอที่ https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Kimi / Moonshot (จีน) — ขอที่ https://platform.moonshot.ai/console/api-keys
MOONSHOT_API_KEY=

# Qwen / Alibaba (จีน) — ขอที่ https://bailian.console.alibabacloud.com/
DASHSCOPE_API_KEY=

# GLM / Zhipu (จีน) — ขอที่ https://z.ai/manage-apikey/apikey-list
ZHIPU_API_KEY=

# Grok / xAI — ขอที่ https://console.x.ai/  (ยังไม่ได้ probe/เทส · ใส่กุญแจแล้วบอกแคลร์ยืนยันรุ่น)
XAI_API_KEY=

# Muse Spark / Meta (เฟซบุค) — ขอที่ https://ai.meta.com/  (ยังไม่ได้ probe/เทส · endpoint+ชื่อรุ่นเป็นตัวเดา · ใส่กุญแจแล้วบอกแคลร์ยืนยัน)
META_API_KEY=
