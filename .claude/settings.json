{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 10,
            "statusMessage": "โหลดกฎการทำงาน (คลังคำ)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-git.sh",
            "if": "Bash(git *)",
            "timeout": 10,
            "statusMessage": "เช็คลิสต์ก่อน git"
          }
        ]
      }
    ]
  }
}
